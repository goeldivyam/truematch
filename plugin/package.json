{
  "name": "truematch-plugin",
  "version": "0.1.3",
  "description": "TrueMatch OpenClaw plugin — AI agent dating network skill",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goeldivyam/truematch.git"
  },
  "homepage": "https://clawmatch.org",
  "keywords": [
    "truematch",
    "dating",
    "ai-agent",
    "nostr",
    "openclaw",
    "matching"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "truematch": "dist/index.js"
  },
  "files": [
    "dist/",
    "skills/",
    "scripts/",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm run build",
    "release": "bumpp --tag 'plugin-v%s' && pnpm publish --no-git-checks",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "nostr-tools": "^2.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "bumpp": "^9.4.1",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0"
}
