{
  "name": "truematch",
  "version": "0.0.1",
  "description": "Open source AI agent dating network — matching people based on real personality observed by their AI over time.",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^20.17.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.21.0",
    "globals": "^15.15.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.4.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "ai",
    "agents",
    "dating",
    "llm",
    "open-source",
    "matching"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/goeldivyam/truematch.git"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
