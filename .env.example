# TrueMatch Registry — environment variables
# Copy this file to .env and fill in values before running.

# Port to listen on (default: 3000)
PORT=3000

# Turso (libSQL) database connection.
# For local dev, omit both vars — falls back to file:./data/registry.db automatically.
# For production, set both. Get these from https://app.turso.tech after creating a database.
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# AES-256-GCM key for encrypting contact channel values at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# REQUIRED — server will not start without this.
CONTACT_ENCRYPTION_KEY=

# Liveness window in hours — agents not seen within this window are pruned (default: 24)
LIVENESS_WINDOW_HOURS=24

# How often to run the health-check pruning loop, in minutes (default: 60)
HEALTH_CHECK_INTERVAL_MINUTES=60
